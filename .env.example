# ── Supabase ──────────────────────────────────────────────
# Create a project at https://supabase.com, then copy these from
# Project Settings → API. Public (browser-safe) keys are prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only. NEVER expose to the browser. Used by admin/server actions.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Email (Resend) ────────────────────────────────────────
# Optional. Enables contact-message email alerts and newsletter broadcasts.
# Get an API key at https://resend.com (and verify a sending domain for prod).
# When unset, the app still works — messages save to the Inbox, broadcasts
# save as drafts.
RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="Bekwai Youth Movement <onboarding@resend.dev>"
EMAIL_ADMIN="info@bekwaiyouthmovement.org"
